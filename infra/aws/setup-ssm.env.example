# Copy to setup-ssm.env (gitignored) and fill in the values, then:
#     set -a; source infra/aws/setup-ssm.env; set +a
#     AWS_PROFILE=goserve bash infra/aws/setup-ssm.sh
#
# This file is the only source of literal secrets the operator owns. It is
# never committed.

# RDS — admin DSN for migrations. Use sslmode=require for RDS.
DATABASE_URL=postgresql://postgres:CHANGE_ME@<rds-endpoint>:5432/postgres?sslmode=require

# Optional — defaults to DATABASE_URL. For real prod, point at the NOBYPASSRLS
# app_user role (created by migration 0001 with literal password "app_user").
# APP_DATABASE_URL=postgresql://app_user:app_user@<rds-endpoint>:5432/postgres?sslmode=require

# Optional — generated with `openssl rand -hex 32` if unset.
# SESSION_SECRET=

# Google OIDC — from https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Filled in after Vercel + Caddy/CloudFront is wired. Example:
#   https://go-serve.vercel.app/api/auth/google/callback
# GOOGLE_OAUTH_REDIRECT_URL=

# Where Google's callback redirects after issuing the session.
POST_LOGIN_REDIRECT_URL=https://go-serve.vercel.app/

# CORS allow-list. Same-origin via Vercel /api/* rewrite means CORS is mostly
# irrelevant, but the API still enforces it on the wire.
CORS_ORIGINS=https://go-serve.vercel.app

# Supabase Storage (or any S3-compatible). Swap to AWS S3 by changing these.
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PUBLIC_URL_BASE=

# SendGrid SMTP relay for shift-end summary emails (0013). Get the API key
# from https://app.sendgrid.com/settings/api_keys (use a "Restricted Access"
# key with Mail Send permission only). MAIL_FROM must be a verified single
# sender or live under a verified domain in SendGrid's Sender Authentication.
SENDGRID_API_KEY=
MAIL_FROM=
