{
  "family": "cafe-mgmt-api",
  "requiresCompatibilities": ["EC2"],
  "networkMode": "bridge",
  "cpu": "1536",
  "memory": "480",
  "executionRoleArn": "arn:aws:iam::782968043912:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::782968043912:role/ecsTaskRole",
  "tags": [
    { "key": "Project", "value": "cafe-mgmt" },
    { "key": "Env", "value": "prod" },
    { "key": "ManagedBy", "value": "deploy-api.yml" }
  ],
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<IMAGE>",
      "essential": true,
      "stopTimeout": 30,
      "memoryReservation": 256,
      "portMappings": [
        { "containerPort": 8080, "hostPort": 80, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "APP_ENV", "value": "prod" },
        { "name": "HTTP_ADDR", "value": ":8080" },
        { "name": "ROOT_DOMAIN", "value": "localhost" },
        { "name": "SESSION_COOKIE_SAMESITE", "value": "none" },
        { "name": "LOG_LEVEL", "value": "info" },
        { "name": "LOG_FORMAT", "value": "json" },
        { "name": "STORAGE_DRIVER", "value": "s3" },
        { "name": "STORAGE_S3_FORCE_PATH_STYLE", "value": "true" },
        { "name": "MAIL_FROM_NAME", "value": "Sahan Cafe" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",                 "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/DATABASE_URL" },
        { "name": "APP_DATABASE_URL",             "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/APP_DATABASE_URL" },
        { "name": "SESSION_SECRET",               "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/SESSION_SECRET" },
        { "name": "GOOGLE_OAUTH_CLIENT_ID",       "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/GOOGLE_OAUTH_CLIENT_ID" },
        { "name": "GOOGLE_OAUTH_CLIENT_SECRET",   "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/GOOGLE_OAUTH_CLIENT_SECRET" },
        { "name": "GOOGLE_OAUTH_REDIRECT_URL",    "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/GOOGLE_OAUTH_REDIRECT_URL" },
        { "name": "GOOGLE_OAUTH_CLIENT_ID_ANDROID", "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/GOOGLE_OAUTH_CLIENT_ID_ANDROID" },
        { "name": "GOOGLE_OAUTH_CLIENT_ID_IOS",   "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/GOOGLE_OAUTH_CLIENT_ID_IOS" },
        { "name": "POST_LOGIN_REDIRECT_URL",      "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/POST_LOGIN_REDIRECT_URL" },
        { "name": "CORS_ORIGINS",                 "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/CORS_ORIGINS" },
        { "name": "STORAGE_S3_ENDPOINT",          "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/STORAGE_S3_ENDPOINT" },
        { "name": "STORAGE_S3_REGION",            "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/STORAGE_S3_REGION" },
        { "name": "STORAGE_S3_BUCKET",            "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/STORAGE_S3_BUCKET" },
        { "name": "STORAGE_S3_ACCESS_KEY_ID",     "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/STORAGE_S3_ACCESS_KEY_ID" },
        { "name": "STORAGE_S3_SECRET_ACCESS_KEY", "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/STORAGE_S3_SECRET_ACCESS_KEY" },
        { "name": "STORAGE_S3_PUBLIC_URL_BASE",   "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/STORAGE_S3_PUBLIC_URL_BASE" },
        { "name": "MAIL_SMTP_HOST",               "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/MAIL_SMTP_HOST" },
        { "name": "MAIL_SMTP_USERNAME",           "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/MAIL_SMTP_USERNAME" },
        { "name": "MAIL_SMTP_PASSWORD",           "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/MAIL_SMTP_PASSWORD" },
        { "name": "MAIL_FROM",                    "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/MAIL_FROM" },
        { "name": "PLATFORM_ADMIN_EMAILS",        "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/PLATFORM_ADMIN_EMAILS" },
        { "name": "ALERT_WEBHOOK_URL",            "valueFrom": "arn:aws:ssm:ap-south-1:782968043912:parameter/cafe-mgmt/prod/ALERT_WEBHOOK_URL" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/cafe-mgmt/api",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "api",
          "awslogs-create-group": "true",
          "mode": "non-blocking",
          "max-buffer-size": "4m"
        }
      }
    }
  ]
}
