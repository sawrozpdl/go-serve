# /opt/cafe/.env — production env for the single-box VPS deploy.
# Loaded by systemd (EnvironmentFile) for the API, and sourced by deploy.sh /
# backup.sh for the migrate binary and pg_dump. chmod 600 this file.
# Var names validated against apps/api/internal/config/config.go.

# --- runtime ---
APP_ENV=prod
HTTP_ADDR=127.0.0.1:8080          # localhost only — Caddy fronts it; not publicly exposed

# --- database (co-located Postgres on this box, loopback so no TLS) ---
# admin role — used by migrate + seed (DDL / CREATE ROLE)
DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/cafe?sslmode=disable
# runtime role — app_user (NOBYPASSRLS) so RLS applies. MUST be set explicitly.
APP_DATABASE_URL=postgresql://app_user:CHANGE_ME@127.0.0.1:5432/cafe?sslmode=disable
DB_MAX_CONNS=10                   # keep PG connection memory bounded on 1 GB

# --- web origin / CORS / auth ---
ROOT_DOMAIN=sarojpaudyal.com.np
CORS_ORIGINS=https://<your-vercel-origin>            # exact origin, no wildcard
# Cross-site SPA(Vercel)↔API: if any auth cookie is still used, uncomment:
# SESSION_COOKIE_SAMESITE=none
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://goserve.sarojpaudyal.com.np/auth/google/callback
POST_LOGIN_REDIRECT_URL=https://<your-vercel-origin>/login/callback
SESSION_SECRET=                    # openssl rand -hex 32  (generate ON the box)

# --- storage: Cloudflare R2 ---
STORAGE_DRIVER=s3
STORAGE_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
STORAGE_S3_REGION=auto             # R2 uses "auto" (us-east-1 also works for signing)
STORAGE_S3_BUCKET=cafe
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PUBLIC_URL_BASE=https://<pub-hash>.r2.dev   # or a custom domain you map to the bucket
STORAGE_S3_FORCE_PATH_STYLE=true

# --- email: SendGrid (optional; OTP/shift-summaries no-op if blank) ---
MAIL_SMTP_HOST=smtp.sendgrid.net
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=apikey
SENDGRID_API_KEY=
MAIL_FROM=no-reply@sarojpaudyal.com.np
MAIL_FROM_NAME=Sahan Cafe

# --- logging ---
LOG_LEVEL=info
LOG_FORMAT=json
PLATFORM_ADMIN_EMAILS=
