# Copy to .env before running `make dev`.

APP_ENV=dev
ROOT_DOMAIN=localhost
CORS_ORIGINS=http://localhost:5891,http://localhost

# Host ports for the dev compose stack. Defaults are non-default to avoid
# clashing with system services (5432, 8080 are commonly taken).
POSTGRES_HOST_PORT=5432
API_HOST_PORT=8081

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# DATABASE_URL is the ADMIN URL used by migrations and the seed script.
# It connects as the postgres owner role (BYPASSRLS, can run DDL).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?sslmode=disable

# APP_DATABASE_URL is the RUNTIME URL used by the API server. It connects as
# `app_user` which is non-superuser and NOBYPASSRLS — so RLS policies apply.
# Created by migration 0001.
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?sslmode=disable

# Web (Vite) — points at the API. Vite dev proxy forwards to this URL.
VITE_API_URL=http://localhost:8081

# Google OIDC (M1) — fill from https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8081/auth/google/callback

# Access-token JWT signing key (HS256). REQUIRED in prod, >=32 bytes — generate
# with: openssl rand -hex 32
SESSION_SECRET=

# Where Google's callback sends the browser after a successful login. With JWT
# auth this is the SPA's /login/callback route, which exchanges a one-time code
# for tokens. NOT /auth/* — that prefix is proxied to the API in dev. Empty
# falls back to "/" on the API origin. Local split-origin example:
#   POST_LOGIN_REDIRECT_URL=http://localhost:5891/login/callback
POST_LOGIN_REDIRECT_URL=

# -----------------------------------------------------------------------------
# Transactional email — SendGrid SMTP (added 2026-05-20)
# -----------------------------------------------------------------------------
# Used for the shift-end summary and the email-OTP sign-in code.
# Leave the credentials empty in dev: the mailer becomes a no-op and the API
# logs OTP codes to stdout so you can copy them out. Any SendGrid-compatible
# relay (Postmark / Mailgun / SES / Postfix) works — defaults below target
# SendGrid SMTP.
MAIL_SMTP_HOST=smtp.sendgrid.net
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=apikey
# Prefer SENDGRID_API_KEY when set; falls back to MAIL_SMTP_PASSWORD otherwise.
SENDGRID_API_KEY=
# MAIL_SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=

# -----------------------------------------------------------------------------
# Email-OTP login (added 2026-05-25) — alternative to Google sign-in
# -----------------------------------------------------------------------------
# All five knobs are optional; the defaults match industry norms (6-digit
# code, 10-minute TTL, 60-second resend cooldown, 5 wrong-attempt cap, 10
# requests/hour per IP). Tune without a redeploy.
# OTP_CODE_LENGTH=6
# OTP_TTL_SECONDS=600
# OTP_RESEND_COOLDOWN_SECONDS=60
# OTP_MAX_ATTEMPTS=5
# OTP_IP_HOURLY_CAP=10
