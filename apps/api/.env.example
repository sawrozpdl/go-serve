# API server — production environment template.
#
# Copy to .env (or inject directly into your platform's env config) for
# any deploy that runs `apps/api` independently. The repo-root .env.example
# is for local dev with the full compose stack.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
APP_ENV=prod                 # dev | test | prod. Disables .env auto-load and dev-login.
HTTP_ADDR=:8080              # bind address (App Runner / ECS expect 8080).

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL is the admin URL — used by `cmd/migrate` and `cmd/seed`.
# Connects as a superuser-ish role that can run DDL and CREATE ROLE.
DATABASE_URL=postgresql://admin:CHANGE_ME@db.example.internal:5432/cafe?sslmode=require

# APP_DATABASE_URL is the runtime URL — used by the API server. Connects as
# `app_user` (NOBYPASSRLS) so RLS policies actually apply. This role is
# created by migration 0001; if APP_DATABASE_URL is unset the server falls
# back to DATABASE_URL (don't do this in prod).
APP_DATABASE_URL=postgresql://app_user:CHANGE_ME@db.example.internal:5432/cafe?sslmode=require

# -----------------------------------------------------------------------------
# Web origin / CORS
# -----------------------------------------------------------------------------
# ROOT_DOMAIN is the registrable domain that owns the session cookie.
#   - sister-subdomain deploy (FE on app.cafe.com, API on api.cafe.com):
#       ROOT_DOMAIN=cafe.com   → cookie set on .cafe.com, SameSite=Lax works.
#   - fully cross-site deploy (FE on cafe.vercel.app, API on api.cafe.com):
#       ROOT_DOMAIN=api.cafe.com (host-only cookie) and SESSION_COOKIE_SAMESITE=none.
#   - CloudFront default domain (api on dxxx.cloudfront.net, no custom domain):
#       ROOT_DOMAIN=localhost  ← sentinel. cloudfront.net is on the Public
#       Suffix List so Domain=.dxxx.cloudfront.net is silently rejected by
#       browsers. A single-label value forces a host-only cookie which works.
#       Switch to the real registrable domain once you wire up a custom domain.
ROOT_DOMAIN=cafe.com

# Comma-separated allow-list of FE origins. Must include scheme + host (and
# port if non-standard). The browser blocks credentialed XHR from any origin
# not on this list.
CORS_ORIGINS=https://app.cafe.com

# Cookie SameSite policy. Lax (default) for sister-subdomain. None for fully
# cross-site (also forces Secure=true regardless of APP_ENV).
SESSION_COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Google OIDC. Create at https://console.cloud.google.com/apis/credentials.
# The redirect URL must exactly match what's registered in Google Console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://api.cafe.com/auth/google/callback

# Access-token JWT signing key (HS256). REQUIRED in prod and must be >=32
# bytes — config.Load() rejects a weak/absent secret. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Access / refresh token lifetimes (Go duration strings). Optional — these are
# the defaults. Access tokens are short (validated statelessly); refresh tokens
# are long-lived, opaque, rotated on use.
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Where Google's callback sends the browser on success. With JWT auth this is
# the SPA's /login/callback route (NOT /auth/* — that prefix is proxied to the
# API by the dev Vite server). The route exchanges a one-time code for tokens.
# Empty falls back to "/" on the API origin (single-origin / local proxy).
#   split-origin (local):  POST_LOGIN_REDIRECT_URL=http://localhost:5891/login/callback
#   split-origin (prod):   POST_LOGIN_REDIRECT_URL=https://goserve.vercel.app/login/callback
POST_LOGIN_REDIRECT_URL=

# -----------------------------------------------------------------------------
# Storage (tenant uploads)
# -----------------------------------------------------------------------------
# STORAGE_DRIVER selects the blob backend.
#   local — write under STORAGE_LOCAL_ROOT and serve via /uploads/* (dev only).
#   s3    — push to any S3-compatible endpoint (Supabase Storage, AWS S3,
#           Cloudflare R2, Backblaze B2, MinIO). The browser fetches the
#           uploaded object directly from STORAGE_S3_PUBLIC_URL_BASE; the
#           API never serves the bytes.
STORAGE_DRIVER=s3

# Local driver — only used when STORAGE_DRIVER=local.
STORAGE_LOCAL_ROOT=./uploads
STORAGE_LOCAL_PUBLIC_BASE=/uploads

# S3-compatible driver — required when STORAGE_DRIVER=s3.
# Supabase example (region matches your Supabase project region):
#   STORAGE_S3_ENDPOINT=https://<ref>.storage.supabase.co/storage/v1/s3
#   STORAGE_S3_REGION=ap-southeast-1
#   STORAGE_S3_BUCKET=cafe-mgmt-uploads
#   STORAGE_S3_PUBLIC_URL_BASE=https://<ref>.storage.supabase.co/storage/v1/object/public/cafe-mgmt-uploads
#   STORAGE_S3_FORCE_PATH_STYLE=true
# Generate access keys at: Supabase dashboard → Storage → S3 access keys.
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PUBLIC_URL_BASE=
STORAGE_S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Transactional email — SendGrid SMTP
# -----------------------------------------------------------------------------
# Powers shift-end summaries and the email-OTP sign-in code. Required in prod
# for the OTP login path (without it the API would log codes to stdout). Any
# SendGrid-compatible relay (Postmark / Mailgun / SES / Postfix) works.
MAIL_SMTP_HOST=smtp.sendgrid.net
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=apikey
# Prefer SENDGRID_API_KEY when set; falls back to MAIL_SMTP_PASSWORD otherwise.
SENDGRID_API_KEY=
# MAIL_SMTP_PASSWORD=
# Verified sender (must be a SendGrid Single Sender or domain-authenticated).
MAIL_FROM=no-reply@cafe.com
MAIL_FROM_NAME=GoServe

# -----------------------------------------------------------------------------
# Email-OTP login — alternative to Google sign-in
# -----------------------------------------------------------------------------
# All five knobs are optional; the defaults match industry norms. Tune without
# a redeploy if you need shorter codes / a longer window / tighter rate caps.
#   OTP_CODE_LENGTH        digits per code, clamped to [4, 8]
#   OTP_TTL_SECONDS        how long a fresh code stays valid
#   OTP_RESEND_COOLDOWN_SECONDS  min seconds between sends to the same email
#   OTP_MAX_ATTEMPTS       wrong verifies before the code is force-consumed
#   OTP_IP_HOURLY_CAP      max sends from one IP over the trailing hour
OTP_CODE_LENGTH=6
OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_IP_HOURLY_CAP=10

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL: debug | info | warn | error. Default info.
# LOG_FORMAT: pretty | json. Empty defaults to pretty in dev/test, json in prod.
LOG_LEVEL=info
LOG_FORMAT=json
PLATFORM_ADMIN_EMAILS=