---
/* Shared window chrome for product mockups — fake titlebar dots + a
 * labeled tab so each surface reads as a screen of the real app. */
type Props = { label: string; ariaLabel: string };
const { label, ariaLabel } = Astro.props;
---

<figure class="mock-frame" role="img" aria-label={ariaLabel}>
  <div class="mock-chrome" aria-hidden="true">
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="mock-label">{label}</span>
  </div>
  <div class="mock-body" aria-hidden="true">
    <slot />
  </div>
</figure>

<style>
  .mock-frame {
    margin: 0;
    background: var(--surface-card);
    border: 1px solid var(--ink-700);
    border-radius: var(--radius-lg);
    box-shadow:
      inset 0 1px 0 var(--bevel-top),
      var(--shadow-xl);
    overflow: hidden;
  }
  .mock-chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--ink-700);
    background: var(--ink-850);
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--ink-600);
  }
  .dot:first-child {
    background: rgba(255, 138, 128, 0.5);
  }
  .mock-label {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-300);
  }
  .mock-body {
    padding: 16px;
  }
</style>
