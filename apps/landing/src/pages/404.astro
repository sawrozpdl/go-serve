---
import Base from '../layouts/Base.astro';
import SteamingCup from '../components/SteamingCup.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Page not found — GoServe" bare>
  <div class="nf">
    <SteamingCup size={56} hero />
    <h1>That table doesn't exist.</h1>
    <p>The page you're after isn't on the menu.</p>
    <a class="btn btn-primary" href={`${base}/`}>Back to GoServe</a>
  </div>
</Base>

<style>
  .nf {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    text-align: center;
    padding: var(--space-7);
  }
  .nf h1 {
    font-size: var(--display-lg);
  }
  .nf p {
    color: var(--ink-200);
  }
</style>
