# Web app — environment template.
#
# Vite reads `.env` / `.env.production` at build time and substitutes any
# `import.meta.env.VITE_*` reference with the literal value. There is no
# runtime env on the FE — the bundle is static after `pnpm build`.

# -----------------------------------------------------------------------------
# Runtime (baked into the bundle)
# -----------------------------------------------------------------------------
# Absolute origin of the API. In dev leave this empty so paths stay relative
# and the Vite proxy forwards them. In prod set the public API URL.
#   dev:  VITE_API_BASE_URL=
#   prod: VITE_API_BASE_URL=https://api.cafe.com
VITE_API_BASE_URL=http://localhost:9090

# Optional: explicit WebSocket origin. Only needed when REST goes through an
# edge proxy that doesn't forward WebSocket upgrades (Vercel rewrites,
# Cloudflare Pages, etc.). Point this at the direct API origin so the WS
# bypasses the proxy. Must be wss:// when the page is served over HTTPS.
#   prod (REST proxied): VITE_WS_BASE_URL=wss://api.cafe.com
#   prod (REST direct):  leave empty — falls back to VITE_API_BASE_URL
VITE_WS_BASE_URL=

# -----------------------------------------------------------------------------
# Dev only (used by vite.config.ts, never reaches the bundle)
# -----------------------------------------------------------------------------
# Where the Vite dev server proxies /v1, /auth, /ws to. Only relevant when
# VITE_API_BASE_URL is empty (i.e., during `pnpm dev`).
VITE_API_URL=http://localhost:9090
WEB_PORT=5891

VITE_CONTACT_EMAIL=pewssh@gmail.com
VITE_CONTACT_PHONE=9800769340
