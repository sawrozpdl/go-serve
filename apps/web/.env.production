# Vite picks this up automatically during `pnpm build` (mode=production).
# These values are baked into the static bundle.
#
# Important: if Vercel has env vars of the same name set in its dashboard,
# those override this file. Either delete them there or keep them in sync.

# Absolute API origin. Cross-origin to the FE — works because the API has
# CORS_ORIGINS=https://goserve.vercel.app and the session cookie is
# SameSite=None; Secure.
VITE_API_BASE_URL=https://goserve.sarojpaudyal.com.np

# WebSocket origin. Same host as REST — Cloudflare terminates TLS and
# forwards the upgrade. Without this the WS would default to the page
# origin (Vercel), which drops WebSocket upgrades.
VITE_WS_BASE_URL=wss://goserve.sarojpaudyal.com.np
