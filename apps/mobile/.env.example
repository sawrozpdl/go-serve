# Copy to `.env` (gitignored) and fill in. Expo inlines EXPO_PUBLIC_* vars into
# the JS bundle at Metro START time — after editing, restart:
#   expo start --dev-client --clear
#
# Point at whichever API you want to test against:
#   - Deployed API:  https://your-api-host          (e.g. https://goserve.example.com)
#   - Local API on your Mac (apps/api/.env → HTTP_ADDR=:9090), from a PHYSICAL phone:
#       http://<your-mac-lan-ip>:9090   (same Wi-Fi; find IP: ipconfig getifaddr en0)
#     Metro runs on :8081, the API on :9090 — no clash.

EXPO_PUBLIC_API_BASE_URL=https://goserve.example.com
EXPO_PUBLIC_WS_BASE_URL=wss://goserve.example.com

# --- Native Google Sign-In ---
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=      # "server"/web client ID (required)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=      # iOS client ID (iOS only)
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=     # reversed iOS client ID (iOS only)
